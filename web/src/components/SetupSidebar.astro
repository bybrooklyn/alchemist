---
import {
    Activity,
    Video,
    Terminal,
    BarChart3,
    Sparkles,
    Wand2,
    Settings,
} from "lucide-react";

const navItems = [
    { label: "Dashboard", Icon: Activity },
    { label: "Jobs", Icon: Video },
    { label: "Logs", Icon: Terminal },
    { label: "Statistics", Icon: BarChart3 },
    { label: "Intelligence", Icon: Sparkles },
    { label: "Convert", Icon: Wand2 },
    { label: "Settings", Icon: Settings },
];
---

<aside
    class="w-full lg:w-64 bg-helios-surface border-b lg:border-b-0
        lg:border-r border-helios-line/60 flex flex-col p-3
        lg:p-4 gap-3 lg:gap-4"
>
    <div class="flex items-center px-3 pb-3 lg:pb-4
        border-b border-helios-line/40">
        <span class="font-bold text-lg tracking-tight text-helios-ink">
            Alchemist
        </span>
    </div>

    <nav class="flex flex-row lg:flex-col gap-2 flex-1
        overflow-x-auto lg:overflow-visible pb-1 lg:pb-0
        opacity-40 pointer-events-none select-none">
        {navItems.map(({ label, Icon }) => (
            <div class="flex items-center gap-3 px-3 py-2 rounded-md
                border-l-2 border-transparent text-helios-slate
                whitespace-nowrap shrink-0">
                <Icon size={18} />
                <span>{label}</span>
            </div>
        ))}
    </nav>

    <div class="hidden lg:block">
        <p class="text-xs text-helios-slate/60 px-3 pb-2 italic">
            Setup in progress
        </p>
    </div>
</aside>
