---
import Layout from "../layouts/Layout.astro";
import { ArrowRight } from "lucide-react";
---

<Layout title="Alchemist | Login">
    <div class="min-h-screen bg-helios-main flex items-center justify-center p-4">
        <div class="w-full max-w-sm">

            <div class="text-center mb-8">
                <span class="text-2xl font-bold tracking-tight text-helios-ink">
                    Alchemist
                </span>
                <p class="text-sm text-helios-slate mt-1">
                    Sign in to continue
                </p>
            </div>

            <div class="bg-helios-surface border border-helios-line/40 rounded-xl p-6 shadow-xl">

                <form id="login-form" class="space-y-4">
                    <div>
                        <label for="username" class="block text-xs font-medium text-helios-slate mb-1.5">
                            Username
                        </label>
                        <input
                            id="username"
                            type="text"
                            name="username"
                            required
                            autocomplete="username"
                            class="w-full bg-helios-surface-soft border border-helios-line/40 rounded-lg px-3 py-2.5 text-sm text-helios-ink focus:border-helios-solar outline-none transition-colors placeholder:text-helios-slate/40"
                            placeholder="admin"
                        />
                    </div>

                    <div>
                        <label for="password" class="block text-xs font-medium text-helios-slate mb-1.5">
                            Password
                        </label>
                        <input
                            id="password"
                            type="password"
                            name="password"
                            required
                            autocomplete="current-password"
                            class="w-full bg-helios-surface-soft border border-helios-line/40 rounded-lg px-3 py-2.5 text-sm text-helios-ink focus:border-helios-solar outline-none transition-colors placeholder:text-helios-slate/40"
                            placeholder="••••••••"
                        />
                    </div>

                    <div id="error-msg" class="hidden px-3 py-2.5 rounded-lg bg-status-error/10 border border-status-error/30 text-status-error text-sm">
                        <span>Invalid credentials</span>
                    </div>

                    <button
                        type="submit"
                        class="w-full flex items-center justify-center gap-2 py-2.5 rounded-lg bg-helios-solar text-helios-main text-sm font-semibold hover:opacity-90 transition-opacity mt-2"
                    >
                        Sign In
                        <ArrowRight size={16} />
                    </button>
                </form>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { apiAction, apiJson, isApiError } from "../lib/api";

    void apiJson<{ setup_required: boolean }>("/api/setup/status")
        .then((data) => {
            if (data?.setup_required) {
                window.location.href = "/setup";
            }
        })
        .catch(() => undefined);

    const form = document.getElementById('login-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg');

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        // Reset error
        errorMsg?.classList.add('hidden');
        
        try {
            await apiAction('/api/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify(data)
            });
            window.location.href = '/';
        } catch (err) {
            console.error("Login failed", err);
            errorMsg?.classList.remove('hidden');
            const message = isApiError(err)
                ? err.status === 401
                    ? "Invalid username or password"
                    : err.message
                : "Connection failed";
            if (errorMsg) errorMsg.querySelector('span')!.textContent = message;
        }
    });
</script>
