---
import Layout from "../layouts/Layout.astro";
import SetupWizard from "../components/SetupWizard";
import SetupSidebar from "../components/SetupSidebar.astro";
---

<Layout title="Alchemist | Setup">
    <div class="app-shell">
        <SetupSidebar />
        <main class="app-main overflow-y-auto">
            <SetupWizard client:only="react" />
        </main>
    </div>
</Layout>

<script>
    import { apiJson } from "../lib/api";
    const basePath = "__ALCHEMIST_BASE_URL__";
    apiJson<{ setup_required: boolean }>("/api/setup/status")
        .then((data) => {
            if (!data.setup_required) {
                window.location.href = `${basePath}/`;
            }
        })
        .catch(() => undefined);
</script>
