---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import SavingsOverview from "../components/SavingsOverview.tsx";
import StatsCharts from "../components/StatsCharts.tsx";
import HeaderActions from "../components/HeaderActions.tsx";
---

<Layout title="Alchemist | Statistics">
    <div class="app-shell">
        <Sidebar />
        <main class="app-main overflow-y-auto">
            <div class="flex items-center justify-end px-6 py-3 border-b border-helios-line/20">
                <HeaderActions client:load />
            </div>
            <div class="p-6">
                <div class="mb-8"><SavingsOverview client:load /></div>
                <StatsCharts client:load />
            </div>
        </main>
    </div>
</Layout>
