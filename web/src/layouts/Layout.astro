---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import ToastRegion from "../components/ui/ToastRegion";
import AuthGuard from "../components/AuthGuard";
import ThemeBootstrap from "../components/ThemeBootstrap";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Alchemist Media Transcoder" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <script is:inline>
            // First-paint theme application. Runs in <head> before any body
            // content is parsed so the cached profile is applied before the
            // browser's first paint — placing this in <body> leaves a visible
            // flash of the default theme. Reads the cached theme id from
            // localStorage so navigating between pages doesn't snap back to
            // the default. Server preference remains authoritative — the
            // ThemeBootstrap island fetches /api/ui/preferences after
            // hydration and overwrites the cache when it returns.
            function initTheme() {
                try {
                    const cached = localStorage.getItem("theme");
                    document.documentElement.setAttribute(
                        "data-color-profile",
                        cached || "helios-orange",
                    );
                } catch {
                    document.documentElement.setAttribute(
                        "data-color-profile",
                        "helios-orange",
                    );
                }
            }

            initTheme();
            document.addEventListener("astro:after-swap", initTheme);
        </script>
        <ClientRouter />
    </head>
    <body>
        <slot />
        <ToastRegion client:load />
        <AuthGuard client:load />
        <ThemeBootstrap client:load />
    </body>
</html>
